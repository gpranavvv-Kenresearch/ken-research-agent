# ── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
# For local dev, SQLite is used by default (no DATABASE_URL needed).
# For production, paste the Render PostgreSQL connection string:
# DATABASE_URL=postgresql://ken_admin:password@host:5432/ken_backend

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
# Free Upstash account: https://upstash.com
# Paste the "rediss://" URL from your Upstash Redis dashboard:
REDIS_URL=rediss://:your-upstash-token@your-endpoint.upstash.io:6379

# ── Celery worker identity ───────────────────────────────────────────────────
# Each team member sets this to their own nickname (lowercase, no spaces)
WORKER_NAME=aniket

# ── Repo path (where your existing scripts/ folder is) ───────────────────────
# The folder ABOVE ken_backend/ (i.e. the root of the full-team-agent repo)
REPO_ROOT=C:/Users/YourName/Desktop/full-team-agent

# ── Google service account (for sheet_write.py) ──────────────────────────────
# Path to your service account JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json

# ── Field encryption (optional but recommended for passwords in DB) ──────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=
