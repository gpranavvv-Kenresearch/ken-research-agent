# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your real values
# Then base64-encode the whole file and store as the ENV_FILE GitHub Secret:
#   base64 -w 0 .env   (Linux/macOS)
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes(".env"))  (PowerShell)
# ─────────────────────────────────────────────────────────────────────────────

# ── NVIDIA NIM API (fallback LLM when OpenRouter is exhausted) ───────────────
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_API_KEY_2=nvapi-your-key-here
NVIDIA_API_KEY_3=nvapi-your-key-here
NVIDIA_API_KEY_4=nvapi-your-key-here

# ── Zenserp — primary SERP provider ─────────────────────────────────────────
ZENSERP_API_KEY_1=your-key-here
ZENSERP_API_KEY_2=your-key-here
ZENSERP_API_KEY_3=your-key-here
ZENSERP_API_KEY_4=your-key-here

# ── Serpstack — fallback SERP provider ──────────────────────────────────────
SERPSTACK_API_KEY_1=your-key-here
SERPSTACK_API_KEY_2=your-key-here
SERPSTACK_API_KEY_3=your-key-here
SERPSTACK_API_KEY_4=your-key-here

# ── SerpAPI — last-resort SERP provider ─────────────────────────────────────
SERPAPI_KEY_1=your-key-here
SERPAPI_KEY_2=your-key-here
SERPAPI_KEY_3=your-key-here
SERPAPI_KEY_4=your-key-here
SERPAPI_KEY_5=your-key-here
SERPAPI_KEY_6=your-key-here
SERPAPI_KEY_7=your-key-here
SERPAPI_KEY_8=your-key-here
SERPAPI_KEY_9=your-key-here
SERPAPI_KEY_10=your-key-here
SERPAPI_KEY_11=your-key-here
SERPAPI_KEY_12=your-key-here

# ── Tavily Web Search API ────────────────────────────────────────────────────
TAVILY_API_KEY_1=tvly-dev-your-key-here
TAVILY_API_KEY_2=tvly-dev-your-key-here
TAVILY_API_KEY_3=tvly-dev-your-key-here
TAVILY_API_KEY_4=tvly-dev-your-key-here
TAVILY_API_KEY_5=tvly-dev-your-key-here
TAVILY_API_KEY_6=tvly-dev-your-key-here
TAVILY_API_KEY_7=tvly-dev-your-key-here
TAVILY_API_KEY_8=tvly-dev-your-key-here
TAVILY_API_KEY_9=tvly-dev-your-key-here
TAVILY_API_KEY_10=tvly-dev-your-key-here

# ── OpenRouter API Keys (LLM routing — auto-rotates when credits run out) ───
OPENROUTER_API_KEY_1=sk-or-v1-your-key-here
OPENROUTER_API_KEY_2=sk-or-v1-your-key-here
OPENROUTER_API_KEY_3=sk-or-v1-your-key-here
OPENROUTER_API_KEY_4=sk-or-v1-your-key-here
OPENROUTER_API_KEY_5=sk-or-v1-your-key-here
OPENROUTER_API_KEY_6=sk-or-v1-your-key-here
OPENROUTER_API_KEY_7=sk-or-v1-your-key-here
OPENROUTER_API_KEY_8=sk-or-v1-your-key-here
OPENROUTER_API_KEY_9=sk-or-v1-your-key-here
OPENROUTER_API_KEY_10=sk-or-v1-your-key-here
OPENROUTER_API_KEY_11=sk-or-v1-your-key-here
OPENROUTER_API_KEY_12=sk-or-v1-your-key-here
OPENROUTER_API_KEY_13=sk-or-v1-your-key-here
OPENROUTER_API_KEY_14=sk-or-v1-your-key-here
OPENROUTER_API_KEY_15=sk-or-v1-your-key-here

# ── Active X account (used when ACCOUNTS_JSON is not set) ───────────────────
X_USERNAME=your-x-username
X_PASSWORD=your-x-password
X_HANDLE=your-x-handle

# ── Microsoft Teams webhook (optional — for posting notifications) ───────────
TEAMS_WEBHOOK_URL=https://your-teams-webhook-url-here
